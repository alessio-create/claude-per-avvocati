# Generated by: openssl rand -base64 32
JWT_SECRET=

# ---- Stripe ----
# From: https://dashboard.stripe.com/apikeys (use live key for prod, test key for dev)
STRIPE_SECRET_KEY=

# From your webhook endpoint in: https://dashboard.stripe.com/webhooks
# Create one pointing to https://<your-domain>/api/webhook/stripe
# Events to listen for: checkout.session.completed, charge.refunded
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for each plan (format: price_xxx)
# Create one Product per plan in Stripe dashboard, copy the Price ID here.
STRIPE_PRICE_AVVOCATO=
STRIPE_PRICE_STUDIO=
STRIPE_PRICE_STUDIO_PLUS=

# Optional: Stripe Price ID for the order-bump (FutureLaw audit, €29).
# Leave empty if you don't want the bump option.
STRIPE_PRICE_BUMP=

# ---- Email (magic link delivery) ----
# From resend.com dashboard
RESEND_API_KEY=
RESEND_FROM_EMAIL="Alessio <ciao@claudeperavvocati.it>"

# ---- KV (buyer records) ----
# Upstash Redis (Vercel marketplace integration injects these automatically)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ---- Site base URL ----
# http://localhost:3002 for dev, https://claudeperavvocati.it for prod
SITE_URL=http://localhost:3002

# ---- Chatbot ----
# Chatbot key, accepts either provider, auto-detected by prefix:
#   sk-ant-... → direct Anthropic (https://console.anthropic.com/settings/keys)
#   sk-or-...  → OpenRouter      (https://openrouter.ai/keys), routes to anthropic/claude-haiku-4.5
ANTHROPIC_API_KEY=
